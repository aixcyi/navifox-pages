        "@navifox/utils": "workspace:*",
        "@tailwindcss/vite": "catalog:",
        "@unhead/vue": "catalog:",
        "@vueuse/core": "catalog:",
        "tailwindcss": "catalog:",
        "vue": "catalog:",
        "vue-router": "catalog:"
    },
    "devDependencies": {
        "@iconify/vue": "catalog:",
        "@types/node": "catalog:",
        "@vitejs/plugin-vue": "catalog:",
