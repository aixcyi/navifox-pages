{
    "name": "navifox-pages",
    "private": true,
    "version": "0.0.0",
    "scripts": {
        "dev:home": "pnpm --filter @navifox/home run dev",
        "build:home": "pnpm --filter @navifox/home run build",
        "preview:home": "pnpm --filter @navifox/home run preview",
        "repreview:home": "pnpm --filter @navifox/home run repreview",
        "clean": "node ./scripts/clean.mjs",
        "reinstall": "pnpm clean --del-lock && pnpm install"
    },
    "dependencies": {
    },
    "devDependencies": {
        "@types/node": "^24.10.8",
        "typescript": "~5.9.3"
    },
    "packageManager": "pnpm@10.28.0",
    "pnpm": {
        "overrides": {
            "vite": "npm:rolldown-vite@7.2.5"
        }
    }
}
