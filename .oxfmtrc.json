{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "tabWidth": 4,
    "printWidth": 120,
    "singleQuote": true,
    "sortPackageJson": false,
    "ignorePatterns": [
        "**/node_modules/*",
        "**/dist/*",
        "**/*.md",
        "./.vscode/*",
        "./.idea/*",
        "*.code-workspace"
    ]
}
